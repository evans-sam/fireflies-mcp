{
	"name": "fireflies-mcp",
	"version": "0.1.0",
	"description": "MCP server and CLI for the Fireflies.ai API",
	"license": "MIT",
	"author": "evans-sam",
	"repository": "evans-sam/fireflies-mcp",
	"homepage": "https://github.com/evans-sam/fireflies-mcp",
	"bugs": "https://github.com/evans-sam/fireflies-mcp/issues",
	"type": "module",
	"bin": {
		"fireflies-mcp": "dist/main.js"
	},
	"files": [
		"dist",
		"src",
		"!src/**/*.test.ts"
	],
	"exports": {
		".": {
			"bun": "./src/main.ts",
			"default": "./dist/main.js"
		},
		"./client": {
			"bun": "./src/client.ts",
			"default": "./dist/main.js"
		}
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"start": "bun run src/main.ts",
		"build": "bun build src/main.ts --outdir dist --target node",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"lint": "biome check",
		"format": "biome check --write",
		"prepublishOnly": "bun run lint && bun run test && bun run build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "1.27.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"bun-types": "^1.3.11",
		"typescript": "^5.6.2"
	}
}
